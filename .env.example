# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE — Required for database, auth, and realtime
# Get these from: Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_URL="https://<project-id>.supabase.co"

# Publishable (anon) key — safe to expose to the browser
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Project ID (used in some SDK calls)
VITE_SUPABASE_PROJECT_ID="<project-id>"

# SERVICE ROLE KEY — server-only, NEVER expose to client
# Required for: admin contact lookup (email + phone), bypassing RLS in notifications
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─────────────────────────────────────────────────────────────────────────────
# GEMINI AI — Required for AI features (bid suggest, crop analysis, routing)
# Get your key at: https://aistudio.google.com/app/apikey
# Key must start with "AIza"
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY="AIza..."

# ─────────────────────────────────────────────────────────────────────────────
# RESEND — Required for transactional email notifications
# Get your key at: https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─────────────────────────────────────────────────────────────────────────────
# TWILIO — Required for SMS notifications on bid events
# Get these at: https://console.twilio.com
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# ─────────────────────────────────────────────────────────────────────────────
# APP — Public URL of this deployment (used in email CTA links)
# Set to your Vercel/Cloudflare/Railway domain after deployment
# ─────────────────────────────────────────────────────────────────────────────
APP_URL="https://your-app-domain.com"

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — Direct Postgres URL (used by apply-schema.mjs)
# Format: postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres"
